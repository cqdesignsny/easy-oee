# ─── Database (Neon, via Vercel Marketplace) ───────────────────────────────
DATABASE_URL=

# ─── Clerk (https://dashboard.clerk.com) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/post-clerk-signin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# ─── Stripe (live mode, on Louis's "Easy OEE Pro" account) ─────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ─── Resend (transactional email) ──────────────────────────────────────────
# Both must be set to actually send mail. With neither set the app falls back
# to a console.log stub so dev never hard-crashes.
RESEND_API_KEY=
EASY_OEE_FROM_EMAIL="Easy OEE <reports@easy-oee.com>"

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Operator PIN session signing secret (32+ random chars) ────────────────
OPERATOR_SESSION_SECRET=

# ─── Cron auth (Bearer ${CRON_SECRET}) for hitting /api/cron/* outside Vercel ─
CRON_SECRET=

# ─── Hardware ingest (Phase 4) ─────────────────────────────────────────────
INGEST_API_KEY=
